  <tr><td>UI-ADM-05</td><td>CreateAccounts</td><td>Sidebar + Form tạo tài khoản đa bước hoặc single form</td><td>Form card white. Input focus teal. Role select dropdown</td><td>Nút "Tạo tài khoản" teal. Nút "Reset form" outline. Icon UserPlus, Shield, Stethoscope</td><td>Role selector (radio cards). Font label bold 13px. Success toast</td></tr>
  <tr><td>UI-ADM-06</td><td>AdminsManagement</td><td>Sidebar + Table admin + Modal thêm admin</td><td>Table header blue-50. Modal: white overlay backdrop-blur</td><td>Nút "+ Thêm Admin" teal. Nút "Xóa" red. Icon Shield, UserMinus, UserPlus</td><td>Modal form fields. Font Admin badge: blue pill</td></tr>
  <tr><td>UI-ADM-07</td><td>AdminPayments</td><td>Sidebar + Stats 3 cards + Table giao dịch + Bộ lọc ngày</td><td>Revenue stat: green bold. Table striped. Badge: green/yellow/red</td><td>Date range filter. Nút "Xuất báo cáo" outline. Icon DollarSign, TrendingUp, Download</td><td>Amount bold VND. Method icon: QR/Card/Momo. Font table 14px</td></tr>
  <tr><td>UI-ADM-08</td><td>AdminReports</td><td>Sidebar + 4 stat cards + By-month table + Chart</td><td>Giống AdminStats. Highlight teal cho tổng doanh thu</td><td>Nút "Tải xuống báo cáo" outline. Icon BarChart, Calendar, FileText</td><td>Monthly breakdown table. Font month header semibold. Revenue teal bold</td></tr>
